# Public access token from https://account.mapbox.com/access-tokens/ (starts with pk.)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here

# Optional; defaults to Mapbox dark style (matches app chrome)
# VITE_MAPBOX_STYLE=mapbox://styles/mapbox/dark-v11

# Optional server environment variables.
# Set these in your shell or hosting provider when needed.
# PAGE_PASSWORD=change-me
# PORT=3001
# CORS_ORIGIN=https://your-site.example
# OASTH_LEGACY_ROUTE_POLE_MAP=1
